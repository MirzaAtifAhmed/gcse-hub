# GCSE Hub API
NODE_ENV=development
PORT=4004

# Local MongoDB example:
# MONGODB_URI=mongodb://127.0.0.1:27017/gcse-hub
# Production MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/gcse-hub?retryWrites=true&w=majority
MONGODB_URI=

# Generate a production secret with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend origin. Use CLIENT_URL in this project.
# Local: http://localhost:5173
# Production: https://your-vercel-app.vercel.app
CLIENT_URL=http://localhost:5173

# Optional seed/admin defaults
ADMIN_EMAIL=admin@gcsehub.local
ADMIN_PASSWORD=Admin123!
